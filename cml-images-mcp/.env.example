# Copy to .env (or set these in the MCP server config "env" block).
CML_BASE_URL=https://your-cml-host
CML_USERNAME=admin
CML_PASSWORD=changeme
# Set to 1/true to enforce TLS cert validation. CML uses a self-signed cert by default,
# so leave unset/false unless you've installed a trusted cert.
CML_VERIFY_TLS=false
